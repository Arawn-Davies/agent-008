#!/usr/bin/env ruby
# frozen_string_literal: true

# agent_008 — a tiny instant messenger for two Claude Code agents, tunneled
# over Tailscale. No third-party service in the loop: `serve` listens only
# on your Tailscale IP, `send` POSTs straight to the peer's Tailscale IP,
# and `recv`/`watch` just poll the local inbox that `serve` filled in.
#
# Two layers of defense: the server only binds to your Tailscale IP (so
# nothing off the tailnet can reach it), and every request must carry a
# shared token the two of you exchanged out of band (so if your tailnet
# ever has more than the two of you on it, network reachability alone
# isn't enough to send you messages).
#
# Delivery is at-least-once and ordered: every message gets a unique id;
# `send` queues to a local outbox and retries (via `flush` or `watch`) if
# the peer isn't reachable right now, instead of silently dropping it;
# `serve` de-dupes by id so a retried message never lands twice.

require "socket"
require "net/http"
require "json"
require "time"
require "optparse"
require "fileutils"
require "securerandom"

CONFIG_DIR = File.join(Dir.home, ".agent_008")
CONFIG_FILE = File.join(CONFIG_DIR, "config.json")
INBOX_FILE = File.join(CONFIG_DIR, "inbox.jsonl")
OUTBOX_FILE = File.join(CONFIG_DIR, "outbox.jsonl")
STATE_FILE = File.join(CONFIG_DIR, "state")
DEFAULT_PORT = 8420
TYPES = %w[message patch prompt chat].freeze

def die(msg)
  warn "agent_008: #{msg}"
  exit 1
end

def load_config
  die "not initialized — run: agent_008 init --peer <host>[:port]" unless File.exist?(CONFIG_FILE)
  JSON.parse(File.read(CONFIG_FILE))
end

def save_config(cfg)
  FileUtils.mkdir_p(CONFIG_DIR)
  File.write(CONFIG_FILE, JSON.pretty_generate(cfg))
end

def default_name
  ENV["AGENT_008_NAME"] || (`whoami`.strip rescue nil) || "unknown"
end

def tailscale_ip
  ip = `tailscale ip -4 2>/dev/null`.strip
  ip.empty? ? nil : ip
end

# --- init ---------------------------------------------------------------

def cmd_init(args)
  opts = { port: DEFAULT_PORT, name: default_name }
  OptionParser.new do |o|
    o.on("--peer HOST") { |v| opts[:peer] = v }
    o.on("--port N", Integer) { |v| opts[:port] = v }
    o.on("--name NAME") { |v| opts[:name] = v }
    o.on("--token TOKEN") { |v| opts[:token] = v }
  end.parse!(args)

  die "--peer is required, e.g. agent_008 init --peer 100.x.y.z:8420" unless opts[:peer]
  opts[:peer] = "#{opts[:peer]}:#{DEFAULT_PORT}" unless opts[:peer].include?(":")

  token = opts[:token] || SecureRandom.hex(24)
  save_config("peer" => opts[:peer], "port" => opts[:port], "name" => opts[:name], "token" => token)
  FileUtils.touch(INBOX_FILE) unless File.exist?(INBOX_FILE)
  FileUtils.touch(OUTBOX_FILE) unless File.exist?(OUTBOX_FILE)
  FileUtils.touch(STATE_FILE) unless File.exist?(STATE_FILE)

  puts "agent_008 initialized: name=#{opts[:name]} peer=#{opts[:peer]} local_port=#{opts[:port]}"
  if opts[:token]
    puts "using the token you provided"
  else
    puts "generated a new token — share it with your peer out of band (same channel as your"
    puts "Tailscale IP, not over agent_008 itself before both sides are configured):"
    puts "  #{token}"
    puts "they need to run: agent_008 init --peer <your-ip> --name <theirs> --token #{token}"
  end
end

# --- serve ------------------------------------------------------------------
# Minimal hand-rolled HTTP/1.1 server (stdlib only — no webrick dependency).
# One endpoint that matters: POST /send with a JSON envelope, guarded by the
# shared token in the Authorization header.

def read_http_request(socket)
  request_line = socket.gets
  return nil if request_line.nil?

  method, path, = request_line.split(" ")
  headers = {}
  while (line = socket.gets) && line != "\r\n"
    key, value = line.split(":", 2)
    headers[key.strip.downcase] = value.strip if key && value
  end
  body = ""
  if (len = headers["content-length"])
    body = socket.read(len.to_i)
  end
  { method: method, path: path, headers: headers, body: body }
end

def write_http_response(socket, status, body)
  reason = { 200 => "OK", 400 => "Bad Request", 401 => "Unauthorized", 404 => "Not Found", 500 => "Internal Server Error" }[status] || "OK"
  socket.write("HTTP/1.1 #{status} #{reason}\r\n")
  socket.write("Content-Type: application/json\r\n")
  socket.write("Content-Length: #{body.bytesize}\r\n")
  socket.write("Connection: close\r\n\r\n")
  socket.write(body)
end

def append_inbox(envelope)
  FileUtils.mkdir_p(CONFIG_DIR)
  File.open(INBOX_FILE, "a") { |f| f.puts(envelope.to_json) }
end

def load_seen_ids
  seen = {}
  if File.exist?(INBOX_FILE)
    File.foreach(INBOX_FILE) do |line|
      id = JSON.parse(line)["id"]
      seen[id] = true if id
    rescue JSON::ParserError
      next
    end
  end
  seen
end

def authorized?(req, token)
  auth = req[:headers]["authorization"]
  return false unless auth

  auth == "Bearer #{token}"
end

def cmd_serve(args)
  cfg = load_config
  opts = { port: cfg["port"] || DEFAULT_PORT, bind: nil }
  OptionParser.new do |o|
    o.on("--port N", Integer) { |v| opts[:port] = v }
    o.on("--bind IP") { |v| opts[:bind] = v }
  end.parse!(args)

  die "no token in config — re-run: agent_008 init --peer <host> --token <shared-secret>" unless cfg["token"]

  bind_ip = opts[:bind] || tailscale_ip
  die "couldn't determine a Tailscale IP (is `tailscale up` running?) — pass one explicitly with --bind <ip>" unless bind_ip

  seen_ids = load_seen_ids
  server = TCPServer.new(bind_ip, opts[:port])
  puts "agent_008 serve: listening on #{bind_ip}:#{opts[:port]} (Tailscale-only, token-checked) as '#{cfg["name"]}' (peer: #{cfg["peer"]})"
  puts "  (Ctrl+C to stop — leave this running, or start it via nohup/tmux/a service — see contrib/)"

  trap("INT") { puts "\nagent_008 serve: stopping"; exit 0 }

  loop do
    client = server.accept
    begin
      req = read_http_request(client)
      next unless req

      if req[:method] == "POST" && req[:path] == "/send"
        unless authorized?(req, cfg["token"])
          warn "agent_008 serve: rejected unauthorized request from #{client.peeraddr(false)[3]}"
          write_http_response(client, 401, { error: "unauthorized" }.to_json)
          next
        end

        payload = JSON.parse(req[:body])
        id = payload["id"] || SecureRandom.uuid

        if seen_ids[id]
          write_http_response(client, 200, { ok: true, id: id, duplicate: true }.to_json)
        else
          envelope = {
            "id" => id,
            "from" => payload["from"] || "unknown",
            "at" => payload["at"] || Time.now.utc.iso8601,
            "received_at" => Time.now.utc.iso8601,
            "type" => TYPES.include?(payload["type"]) ? payload["type"] : "message",
            "body" => payload["body"] || "",
          }
          append_inbox(envelope)
          seen_ids[id] = true
          puts "[#{envelope["received_at"]}] (#{envelope["type"]}) from #{envelope["from"]} [#{id}] (#{envelope["body"].to_s.bytesize} bytes)"
          write_http_response(client, 200, { ok: true, id: id }.to_json)
        end
      elsif req[:method] == "GET" && req[:path] == "/health"
        write_http_response(client, 200, { ok: true, name: cfg["name"] }.to_json)
      else
        write_http_response(client, 404, { error: "not found" }.to_json)
      end
    rescue StandardError => e
      warn "agent_008 serve: error handling request: #{e.message}"
      begin
        write_http_response(client, 500, { error: e.message }.to_json)
      rescue StandardError
        nil
      end
    ensure
      client.close
    end
  end
end

# --- delivery (shared by send / flush / watch) -------------------------------

def deliver(envelope, peer, token)
  host, port = peer.split(":")
  port ||= DEFAULT_PORT
  uri = URI("http://#{host}:#{port}/send")
  res = Net::HTTP.start(uri.host, uri.port, open_timeout: 5, read_timeout: 5) do |http|
    req = Net::HTTP::Post.new(uri.path, "Content-Type" => "application/json", "Authorization" => "Bearer #{token}")
    req.body = envelope.to_json
    http.request(req)
  end
  return true if res.code.to_i == 200
  die "peer rejected our token (401) — confirm both sides ran `init` with the same --token" if res.code.to_i == 401

  false
rescue StandardError
  false
end

def queue_outbox(envelope)
  FileUtils.mkdir_p(CONFIG_DIR)
  File.open(OUTBOX_FILE, "a") { |f| f.puts(envelope.to_json) }
end

# Delivers queued messages in order, stopping at the first failure (so a
# down peer doesn't reorder delivery). Returns the number successfully sent.
def flush_outbox(peer, token, quiet: false)
  lines = File.exist?(OUTBOX_FILE) ? File.readlines(OUTBOX_FILE) : []
  return 0 if lines.empty?

  remaining = []
  delivered = 0
  lines.each do |line|
    envelope = JSON.parse(line)
    if remaining.empty? && deliver(envelope, peer, token)
      delivered += 1
      puts "flushed queued (#{envelope["type"]}) [#{envelope["id"]}]" unless quiet
    else
      remaining << line
    end
  end
  File.write(OUTBOX_FILE, remaining.join)
  delivered
end

# --- send -----------------------------------------------------------------

def cmd_send(args)
  cfg = load_config
  peer = cfg["peer"]
  type = "message"
  patch_file = nil
  use_diff = false
  OptionParser.new do |o|
    o.on("--to HOST") { |v| peer = v }
    o.on("--type TYPE", TYPES) { |v| type = v }
    o.on("--patch FILE") { |v| patch_file = v; type = "patch" }
    o.on("--diff") { use_diff = true; type = "patch" }
  end.parse!(args)
  die "no peer configured — run: agent_008 init --peer <host>[:port]" unless peer

  body =
    if patch_file
      die "no such file: #{patch_file}" unless File.exist?(patch_file)
      File.read(patch_file)
    elsif use_diff
      diff = `git diff`
      die "git diff produced no output (nothing unstaged in this directory?)" if diff.strip.empty?
      diff
    elsif args == ["-"] || (args.empty? && !$stdin.tty?)
      $stdin.read
    else
      args.join(" ")
    end
  die "empty message — pass text, pipe stdin (agent_008 send -), or use --patch/--diff" if body.nil? || body.strip.empty?

  envelope = {
    "id" => SecureRandom.uuid,
    "from" => cfg["name"],
    "at" => Time.now.utc.iso8601,
    "type" => type,
    "body" => body,
  }

  # Try any already-queued messages first so delivery stays in order.
  flush_outbox(peer, cfg["token"], quiet: true)

  if deliver(envelope, peer, cfg["token"])
    puts "sent (#{type}) to #{peer} [#{envelope["id"]}] (#{body.bytesize} bytes)"
  else
    queue_outbox(envelope)
    warn "agent_008: #{peer} unreachable right now — queued [#{envelope["id"]}]. " \
         "It'll go out via `agent_008 flush` or the next `agent_008 watch` poll — nothing is lost."
  end
end

# --- flush / outbox ---------------------------------------------------------

def cmd_flush(_args)
  cfg = load_config
  delivered = flush_outbox(cfg["peer"], cfg["token"])
  pending = File.exist?(OUTBOX_FILE) ? File.readlines(OUTBOX_FILE).size : 0
  puts "agent_008 flush: delivered #{delivered}, #{pending} still pending" if delivered.zero? || pending.positive?
end

def cmd_outbox(_args)
  lines = File.exist?(OUTBOX_FILE) ? File.readlines(OUTBOX_FILE) : []
  return puts("(outbox empty)") if lines.empty?

  lines.each do |line|
    e = JSON.parse(line)
    preview = e["body"].to_s.tr("\n", " ")[0, 60]
    puts "[#{e["id"]}] (#{e["type"]}) queued at #{e["at"]}: #{preview}"
  end
end

# --- recv / watch -----------------------------------------------------------

def cursor_get
  File.exist?(STATE_FILE) ? File.read(STATE_FILE).strip.to_i : 0
end

def cursor_set(n)
  FileUtils.mkdir_p(CONFIG_DIR)
  File.write(STATE_FILE, n.to_s)
end

def cmd_recv(args)
  load_config # just to give a clean error if uninitialized
  show_all = args.include?("--all")
  as_json = args.include?("--json")
  save_dir = nil
  if (i = args.index("--save-patches"))
    save_dir = args[i + 1]
    die "--save-patches needs a directory argument" unless save_dir
    FileUtils.mkdir_p(save_dir)
  end

  lines = File.exist?(INBOX_FILE) ? File.readlines(INBOX_FILE) : []
  start = show_all ? 0 : cursor_get
  new_lines = lines[start..] || []

  if new_lines.empty?
    puts "(no new messages)" unless as_json
    return false
  end

  new_lines.each do |line|
    envelope = JSON.parse(line)
    type = envelope["type"] || "message"

    if save_dir && type == "patch"
      path = File.join(save_dir, "#{envelope["id"] || Time.now.to_i}.patch")
      File.write(path, envelope["body"].to_s)
      puts "saved patch from @#{envelope["from"]} -> #{path} (git apply #{path})" unless as_json
    end

    if as_json
      puts envelope.to_json
    else
      tag = type == "message" ? "" : " [#{type}]"
      puts "── from @#{envelope["from"]}#{tag} at #{envelope["at"]} ──"
      envelope["body"].to_s.each_line { |l| puts "  #{l.chomp}" }
      puts
    end
  end

  cursor_set(lines.length) unless show_all
  true
end

def cmd_watch(_args)
  cfg = load_config
  delivered = flush_outbox(cfg["peer"], cfg["token"], quiet: true)
  found = cmd_recv([])
  bits = []
  bits << "flushed #{delivered} queued" if delivered.positive?
  bits << (found ? "new messages above" : "nothing new")
  puts "agent_008 watch: #{bits.join(", ")}"
end

# --- chat --------------------------------------------------------------
# A plain human-to-human REPL over the same tunnel — for when you two just
# want to talk directly instead of going through an agent. Deliberately
# doesn't touch the shared `recv` cursor (it tails the inbox on its own),
# so chatting never marks messages "already seen" for an agent's `watch`.

def cmd_chat(_args)
  cfg = load_config
  peer = cfg["peer"]
  puts "agent_008 chat: talking to #{peer} as '#{cfg["name"]}'. /quit to exit."

  stop = false
  last_size = File.exist?(INBOX_FILE) ? File.readlines(INBOX_FILE).size : 0
  tailer = Thread.new do
    until stop
      sleep 1
      lines = File.exist?(INBOX_FILE) ? File.readlines(INBOX_FILE) : []
      next unless lines.size > last_size

      lines[last_size..].each do |line|
        envelope = JSON.parse(line)
        print "\r\e[K#{envelope["from"]}: #{envelope["body"].to_s.chomp}\n"
      rescue JSON::ParserError
        next
      end
      last_size = lines.size
      print "you> "
      $stdout.flush
    end
  end

  loop do
    print "you> "
    $stdout.flush
    line = $stdin.gets
    break if line.nil?

    line = line.chomp
    break if line == "/quit"
    next if line.strip.empty?

    envelope = { "id" => SecureRandom.uuid, "from" => cfg["name"], "at" => Time.now.utc.iso8601,
                 "type" => "chat", "body" => line }
    flush_outbox(peer, cfg["token"], quiet: true)
    unless deliver(envelope, peer, cfg["token"])
      queue_outbox(envelope)
      puts "  (#{peer} unreachable — queued, will retry)"
    end
  end
ensure
  stop = true
  tailer&.kill
  puts "\nagent_008 chat: bye"
end

# --- main -------------------------------------------------------------------

USAGE = <<~TXT
  agent_008 — instant messenger for agents, tunneled over Tailscale

  Usage:
    agent_008 init --peer <tailscale-host>[:port] [--port N] [--name NAME] [--token TOKEN]
        One-time setup: peer's Tailscale address, your listen port
        (default #{DEFAULT_PORT}), your display name, and a shared auth
        token. Omit --token to generate one — share it with your peer out
        of band, they pass the SAME value with --token on their `init`.

    agent_008 serve [--port N] [--bind IP]
        Starts the local mailbox server (foreground), bound only to your
        Tailscale IP, checking every request against the shared token. Run
        continuously (nohup, tmux, or contrib/ service).

    agent_008 send ("<text>" | -) [--type message|patch|prompt]
    agent_008 send --patch <file>          # shorthand for --type patch
    agent_008 send --diff                  # shorthand: body = `git diff` here
        Sends to the configured peer. If the peer's unreachable right now,
        the message is queued to a local outbox instead of being dropped —
        it retries automatically on the next `send`, `flush`, or `watch`.

    agent_008 flush
        Retries everything in the outbox, in order, stopping at the first
        still-unreachable message (keeps delivery order intact).

    agent_008 outbox
        Lists messages still waiting to be delivered.

    agent_008 recv [--all] [--json] [--save-patches DIR]
        Polls the LOCAL inbox (filled in by `serve`) for messages since you
        last checked — no network call, safe to run often. --save-patches
        writes any patch-typed message straight to a .patch file.

    agent_008 watch
        One poll pass for the /loop skill: flushes the outbox, then checks
        the inbox. Always exits 0.
            /loop 1m /agent_008 watch

    agent_008 chat
        Plain human-to-human REPL over the same tunnel.

  Config: ~/.agent_008/config.json
  Inbox:  ~/.agent_008/inbox.jsonl    Outbox: ~/.agent_008/outbox.jsonl
TXT

def main
  cmd = ARGV.shift
  case cmd
  when "init" then cmd_init(ARGV)
  when "serve" then cmd_serve(ARGV)
  when "send" then cmd_send(ARGV)
  when "flush" then cmd_flush(ARGV)
  when "outbox" then cmd_outbox(ARGV)
  when "recv" then cmd_recv(ARGV)
  when "watch" then cmd_watch(ARGV)
  when "chat" then cmd_chat(ARGV)
  when "-h", "--help", "help", nil then puts USAGE
  else
    die "unknown command '#{cmd}' — run: agent_008 help"
  end
end

main
